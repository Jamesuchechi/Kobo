# Copy this file to .env and fill in real values.
# See scripts/setup_datahub.sh and DOCUMENTATION.md for how each is used.

# --- DataHub connection ---
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_GMS_TOKEN=

# --- LLM (explanation generation) ---
OPENROUTER_API_KEY=

# --- Reconciliation agent tuning ---
# Minimum delta (percentage of expected payout) before a finding is written back.
MISMATCH_SEVERITY_THRESHOLD=0.02

# "direct" writes tags/properties/documents immediately.
# "proposal" submits changes via DataHub's governed proposal workflow instead.
WRITEBACK_MODE=direct

# --- Mock data ---
MOCK_DATA_SEED=42
